# FIA Database Configuration
# Copy this file to .env and update with your actual database path
# This file should NOT be committed to version control (add to .gitignore)

# Path to the FIA SQLite database file
# Examples:
#   FIA_DB_PATH=/data/FIA/FIA_database.db
#   FIA_DB_PATH=./data/FIA_database.db
#   FIA_DB_PATH=/mnt/external_drive/FIA_data.db
FIA_DB_PATH=path/to/your/FIA_database.db

# Optional: Set output directory for generated files
OUTPUT_DIR=./output

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
